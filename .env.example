# Respan MCP Server - Environment Variables

# Required: Your Respan API key (for stdio mode)
# RESPAN_API_KEY=your_respan_api_key

# Optional: Override the default API base URL
# RESPAN_API_BASE_URL=https://api.respan.ai/api

# Required for HTTP/Vercel deployment: Secret used to sign OAuth tokens (auth codes, client registrations)
# OAUTH_SECRET=your_random_secret_here
